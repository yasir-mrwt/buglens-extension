{
  "name": "testpilot-ai-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local TestPilot AI backend for Ollama-powered QA analysis.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/server.js",
    "dev": "npm run build && node dist/server.js",
    "health": "npm run build && node dist/scripts/health-check.js",
    "test:integration": "npm run build && node --test tests/routes.integration.test.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2"
  }
}
